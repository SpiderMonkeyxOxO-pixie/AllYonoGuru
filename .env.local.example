# Copy this file to .env.local and fill in real values before running.

# Strapi backend URL (default: local dev)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Strapi API token — generate in Strapi Admin > Settings > API Tokens
STRAPI_API_TOKEN=

# Google Analytics 4 Measurement ID — only loads after a visitor accepts
# the cookie consent banner. Leave blank to disable analytics entirely.
NEXT_PUBLIC_GA_ID=
