# Copy to .env and fill in values before starting Strapi.

HOST=0.0.0.0
PORT=1337

# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=changeme
ADMIN_JWT_SECRET=changeme
TRANSFER_TOKEN_SALT=changeme
JWT_SECRET=changeme
ENCRYPTION_KEY=changeme

# Database (leave blank to use SQLite for local dev)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# For production Postgres:
# DATABASE_CLIENT=postgres
# DATABASE_HOST=
# DATABASE_PORT=5432
# DATABASE_NAME=allyonoguru
# DATABASE_USERNAME=
# DATABASE_PASSWORD=
# DATABASE_SSL=false

# Seed script token (Strapi Admin → Settings → API Tokens → Full Access)
STRAPI_SEED_TOKEN=
